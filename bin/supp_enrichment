extract_results <- function( enrich, gene_set){ 
    pvals_funcs = sapply(1:length(enrich), function(i)  enrich[[i]][,5] ) 
    p_funcs =  apply(sapply(1:length(enrich), function(i)  enrich[[i]][,3] ),2, as.numeric) + 1   
    padj_funcs = apply(pvals_funcs, 2, p.adjust)

    rownames(p_funcs)     = enrich[[1]][,1]
    rownames(pvals_funcs) = enrich[[1]][,1]
    rownames(padj_funcs)  = enrich[[1]][,1]
    colnames(p_funcs)     = colnames(gene_set)
    colnames(pvals_funcs) = colnames(gene_set)
    colnames(padj_funcs)  = colnames(gene_set)
    q_func = as.numeric(enrich[[1]][,4]) 
    names(q_func) = enrich[[1]][,1]
   return( list(p_funcs,pvals_funcs, padj_funcs , q_func)  )
}



results_list=list()
for(i in 1:length(types)){
  
  type = types[i]
  annots = annots_list[[i]]
  voc = voc_list[[i]] 

  enrich_degs = lapply(1:dim(sex_genes_mat_wilcox)[2], function(i) gene_set_enrichment( names(which(sex_genes_mat_wilcox[,i] > 0) ) , annots, voc) )
  pvals = sapply(1:length(enrich_degs), function(i) enrich_degs[[i]][,5])
  
  pvals = apply(pvals, 2, as.numeric)
  rownames(pvals) =  enrich_degs[[1]][,1]
  colnames(pvals) =  colnames(sex_genes_mat_wilcox) 
  
  padj = apply(pvals, 2, p.adjust)
  rownames(padj) =  rownames(pvals) 
  colnames(padj) =  colnames(pvals) 
  
  pp = sapply(1:length(enrich_degs), function(i) enrich_degs[[i]][,3])
  pp = apply(pp, 2, as.numeric)
  rownames(pp) =  rownames(pvals) 
  colnames(pp) =  colnames(pvals) 
  
  pp = pp + 1  
   
  save(pvals, padj, col_filt, col_cols, pp, celltypes, enrich_degs, file=paste0(maindir,"/enrich/enrich_degs_annots_", type,".Rdata")) 
   results = extract_results(enrich_degs,sex_genes_mat_wilcox )
   results_list[[i]] = results

}

names(results_list) = types

save( results_list, types, file="enrich/enrich_degs_parsed.Rdata")



