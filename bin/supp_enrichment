temp = read.table("annotations/huang_sex_2021",header=T)
temp = as.data.frame(temp)
temp_old = temp[temp[,2] == "OM_v_OF",-2]
temp_young = temp[temp[,2] == "YM_v_YF",-2]

temp_old = spread(temp_old, key=1, val=3, fill=0) 
temp_young = spread(temp_young, key=1, val=3, fill=0) 

rownames(temp_old) = temp_old[,1] 
rownames(temp_young) = temp_young[,1] 

temp_young = temp_young[,-1]
temp_old = temp_old[,-1]

g2 = rownames(temp_old)
g1 = rownames(temp_young)

temp_young = apply(temp_young, 2, as.numeric)
temp_young_M = 1*(temp_young > 0)
temp_young_F = -1*(temp_young < 0)
huang_young = temp_young_M + temp_young_F
rownames(huang_young)  =  g1


temp_old = apply(temp_old, 2, as.numeric)
temp_old_M = 1*(temp_old > 0)
temp_old_F = -1*(temp_old < 0)
huang_old = temp_old_M + temp_old_F
rownames(huang_old)  =  g2

g3 = unique(c(g1,g2))
m = match(g3,g2)
temp_old_M2 = temp_old_M[m,]
temp_old_F2 = temp_old_F[m,]
rownames(temp_old_M2) = g3
rownames(temp_old_F2) = g3
colnames(temp_old_M2) = paste("male old", colnames(temp_old_M))
colnames(temp_old_F2) = paste("female old", colnames(temp_old_F))

m = match(g3,g1)
temp_young_F2 = temp_young_F[m,]
temp_young_M2 = temp_young_M[m,]
rownames(temp_young_M2) = g3
rownames(temp_young_F2) = g3
colnames(temp_young_M2) = paste("male young", colnames(temp_young_M))
colnames(temp_young_F2) = paste("female young", colnames(temp_young_F))

 
temp_old_F2[is.na(temp_old_F2)] = 0
temp_young_M2[is.na(temp_young_M2)] = 0
temp_young_F2[is.na(temp_young_F2)] = 0
temp_old_M2[is.na(temp_old_M2)] = 0


temp_old_F2 = 1*(temp_old_F2 != 0) 
temp_young_F2 = 1*(temp_young_F2 != 0) 

huang2021 = cbind(temp_young_F2, temp_young_M2, temp_old_F2, temp_old_M2)

 
huang2021_female_old = 1*(rowSums(temp_old_F2, na.rm=T) > 0) 
huang2021_male_old = 1*(rowSums(temp_old_M2, na.rm=T)> 0) 
huang2021_female_young = 1*(rowSums(temp_young_F2, na.rm=T)> 0) 
huang2021_male_young = 1*(rowSums(temp_young_M2, na.rm=T)> 0) 

